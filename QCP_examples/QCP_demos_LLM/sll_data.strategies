//data-carrying counterpart of sll_shape.strategies
//listrep(p)  ~  sll(p, l)
//lseg(p, q)  ~  sllseg(p, q, l)
//max rule id:30

#include "sll_data_def.h"



id : 3
priority : core(0)
left : sll(NULL, ?l) at 0
action : left_erase(0);
         left_add(l == nil{Z});

id : 4
priority : core(0)
right : sll(NULL, ?l) at 0
action : right_erase(0);
         right_add(l == nil{Z});

id : 5
priority : core(0)
left : (?p : Z == NULL || NULL == ?p : Z) at 0
right : sll(p, ?l) at 1
action : right_erase(1);
         right_add(l == nil{Z});

id : 6
priority : core(1)
left : sll(?p : Z, ?l) at 0
       (p == NULL || NULL == p) at 1
action : left_erase(0);
         left_add(l == nil{Z});

id : 7
priority : core(5)
left : sll(?p : Z, ?l1) at 0
right : sll(p, ?l2) at 1
action : left_erase(0);
         right_erase(1);
         right_add(l1 == l2);

id : 8
priority : core(6)
left : sll(?p : Z, ?l) at 0
       (p != NULL || NULL != p) at 1
right : (store(field_addr(p, list, data), I32, ?q : Z) || store(field_addr(p, list, next), PTR(struct list), ?q : Z)) at 2
action : left_erase(0);
         left_exist_add(x : Z);
         left_exist_add(y : Z);
         left_exist_add(l0);
         left_add(store(field_addr(p, list, data), I32, x));
         left_add(store(field_addr(p, list, next), PTR(struct list), y));
         left_add(sll(y, l0));
         left_add(l == cons{Z}(x, l0));

id : 9
priority : core(6)
left : (?p : Z != NULL || NULL != ?p : Z) at 0
right : sll(p, ?l) at 1
action : right_erase(1);
         right_exist_add(x : Z);
         right_exist_add(y : Z);
         right_exist_add(l0);
         right_add(store(field_addr(p, list, data), I32, x));
         right_add(store(field_addr(p, list, next), PTR(struct list), y));
         right_add(sll(y, l0));
         right_add(l == cons{Z}(x, l0));

id : 10
priority : core(3)
left : sllseg(?p : Z, ?q : Z, ?l1) at 0
right : sll(p, ?l2) at 1
action: left_erase(0);
        right_erase(1);
        right_exist_add(l3);
        right_add(sll(q, l3));
        right_add(l2 == app{Z}(l1, l3));

